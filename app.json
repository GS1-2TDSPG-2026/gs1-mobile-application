{
  "expo": {
    "name": "Phycocarbon",
    "slug": "phycocarbon-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/phycocarbon-splash-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/phycocarbon-splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/phycocarbon-splash-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/phycocarbon-splash-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/images/phycocarbon-splash-icon.png"
    }
  }
}